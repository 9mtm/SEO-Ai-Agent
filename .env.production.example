# ========================================
# DATABASE CONFIGURATION
# ========================================
DB_HOST=your_server_ip_or_domain
DB_USER=seo_agent_user
DB_PASSWORD=your_strong_database_password_here
DB_NAME=seo_agent_db
DB_PORT=3306

# ========================================
# APPLICATION CONFIGURATION
# ========================================
NODE_ENV=production
PORT=3000
NEXT_PUBLIC_API_URL=https://seo-agent.net

# ========================================
# GOOGLE OAUTH CONFIGURATION
# ========================================
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=https://seo-agent.net/api/auth/google/callback

# ========================================
# JWT & SECURITY
# ========================================
JWT_SECRET=your_very_secure_jwt_secret_min_32_characters_random_string
NEXTAUTH_SECRET=your_nextauth_secret_here_also_32_chars_min
NEXTAUTH_URL=https://seo-agent.net

# ========================================
# STRIPE PAYMENT (if using)
# ========================================
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ========================================
# EMAIL CONFIGURATION (SMTP)
# ========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_specific_password
EMAIL_FROM=noreply@seo-agent.net

# ========================================
# SCRAPER CONFIGURATION
# ========================================
SCRAPER_API_KEY=your_scraper_api_key_if_needed

# ========================================
# GOOGLE SERVICE ACCOUNT (for GSC)
# ========================================
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour private key here\n-----END PRIVATE KEY-----\n"

# ========================================
# LOGGING & MONITORING
# ========================================
LOG_LEVEL=info
ENABLE_LOGGING=true

# ========================================
# RATE LIMITING
# ========================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ========================================
# CORS CONFIGURATION
# ========================================
ALLOWED_ORIGINS=https://seo-agent.net,https://www.seo-agent.net

# ========================================
# SESSION CONFIGURATION
# ========================================
SESSION_SECRET=your_session_secret_32_chars_minimum_random
SESSION_MAX_AGE=86400000

# ========================================
# MCP SERVER CONFIGURATION
# ========================================
MCP_SERVER_ENABLED=true
MCP_API_BASE_URL=https://seo-agent.net
